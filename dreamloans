.wa-float{position:fixed;bottom:1.8rem;right:1.8rem;z-index:300;width:52px;height:52px;border-radius:50%;background:#25D366;display:flex;align-items:center;justify-content:center;box-shadow:0 5px 18px rgba(37,211,102,.4);cursor:pointer;text-decoration:none;transition:transform .2s;}
