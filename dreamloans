/* ── TOAST ── */
.toast{position:fixed;bottom:4.5rem;left:50%;transform:translateX(-50%) translateY(14px);background:var(--navy);color:#fff;padding:10px 20px;border-radius:8px;font-size:13px;border-left:4px solid var(--gold);opacity:0;transition:all .3s;z-index:999;pointer-events:none;white-space:nowrap;}
