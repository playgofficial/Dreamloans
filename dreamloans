<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Dream Loans Financial Services | Fast Loans Across India</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<style>
:root{--navy:#0B1F3A;--navy-mid:#152D52;--navy-light:#1E3F6F;--gold:#C9A84C;--gold-light:#E2C87A;--gold-pale:#F9F3E3;--white:#fff;--off:#F7F8FA;--tm:#3A5070;--tmu:#7A90A8;--bdr:#DDE3EC;}
*{margin:0;padding:0;box-sizing:border-box;}html{scroll-behavior:smooth;}
body{font-family:'DM Sans',sans-serif;color:var(--navy);background:var(--white);overflow-x:hidden;}
.page{display:none;animation:fu .42s ease both;}.page.active{display:block;}
@keyframes fu{from{opacity:0;transform:translateY(16px)}to{opacity:1;transform:translateY(0)}}

/* ── NAV ── */
nav{position:fixed;top:0;left:0;right:0;z-index:200;display:flex;align-items:center;justify-content:space-between;padding:.95rem 5%;background:rgba(11,31,58,.97);backdrop-filter:blur(12px);border-bottom:1px solid rgba(201,168,76,.2);}
.nav-logo{display:flex;align-items:center;gap:10px;text-decoration:none;cursor:pointer;}
.nav-logo-icon{width:36px;height:36px;border-radius:7px;background:linear-gradient(135deg,var(--gold),var(--gold-light));display:flex;align-items:center;justify-content:center;}
.nav-logo-icon svg{width:19px;height:19px;}
.nav-brand-name{font-family:'Playfair Display',serif;font-size:14.5px;color:#fff;font-weight:600;line-height:1.1;}
.nav-brand-sub{font-size:9.5px;color:var(--gold-light);letter-spacing:.12em;text-transform:uppercase;}
.nav-links{display:flex;align-items:center;gap:1.5rem;}
.nav-links a{text-decoration:none;font-size:13px;color:rgba(255,255,255,.7);transition:color .2s;cursor:pointer;border:none;background:none;font-family:'DM Sans',sans-serif;padding:0;}
.nav-links a:hover,.nav-links a.al{color:var(--gold-light);}
.nav-phone{display:flex;align-items:center;gap:6px;color:var(--gold-light);font-size:13px;font-weight:500;text-decoration:none;}
.nav-phone svg{width:13px;height:13px;}
.nav-cta{background:var(--gold);color:var(--navy);border:none;padding:8px 18px;border-radius:6px;font-size:13px;font-weight:500;cursor:pointer;font-family:'DM Sans',sans-serif;}
.nav-cta:hover{background:var(--gold-light);}
.hamburger{display:none;flex-direction:column;gap:5px;cursor:pointer;border:none;background:none;padding:4px;}
.hamburger span{width:22px;height:2px;background:#fff;border-radius:2px;}
.mob-menu{display:none;position:fixed;top:60px;left:0;right:0;background:rgba(11,31,58,.98);padding:1.3rem 5%;z-index:199;flex-direction:column;gap:.85rem;border-bottom:1px solid rgba(201,168,76,.15);}
.mob-menu a{color:rgba(255,255,255,.8);text-decoration:none;font-size:15px;cursor:pointer;}
.mob-menu.open{display:flex;}

/* ── HERO ── */
.hero{min-height:100vh;background:var(--navy);display:flex;align-items:center;position:relative;overflow:hidden;padding:118px 5% 80px;}
.hero-bg{position:absolute;inset:0;pointer-events:none;background-image:radial-gradient(circle at 72% 50%,rgba(201,168,76,.07),transparent 55%),radial-gradient(circle at 10% 80%,rgba(30,63,111,.8),transparent 40%);}
.hero-grid{position:absolute;right:0;top:0;bottom:0;width:45%;pointer-events:none;opacity:.05;}
.hero-content{position:relative;max-width:580px;}
.hero-eyebrow{display:inline-flex;align-items:center;gap:8px;font-size:11px;letter-spacing:.18em;text-transform:uppercase;color:var(--gold);margin-bottom:1.3rem;}
.hero-eyebrow::before{content:'';width:24px;height:1px;background:var(--gold);}
.hero-title{font-family:'Playfair Display',serif;font-size:clamp(2.5rem,5vw,3.9rem);font-weight:700;color:#fff;line-height:1.12;margin-bottom:1.3rem;}
.hero-title em{color:var(--gold);font-style:normal;}
.hero-desc{font-size:15.5px;color:rgba(255,255,255,.57);line-height:1.78;margin-bottom:2.3rem;font-weight:300;max-width:460px;}
.hero-actions{display:flex;gap:11px;flex-wrap:wrap;}
.btn-gold{display:inline-flex;align-items:center;gap:7px;background:var(--gold);color:var(--navy);padding:12px 24px;border-radius:7px;font-size:14px;font-weight:500;text-decoration:none;transition:all .2s;border:none;cursor:pointer;font-family:'DM Sans',sans-serif;}
.btn-gold:hover{background:var(--gold-light);transform:translateY(-1px);}
.btn-outline{display:inline-flex;align-items:center;gap:7px;background:transparent;color:#fff;padding:12px 24px;border-radius:7px;font-size:14px;font-weight:400;text-decoration:none;transition:all .2s;border:1px solid rgba(255,255,255,.25);cursor:pointer;font-family:'DM Sans',sans-serif;}
.btn-outline:hover{border-color:var(--gold);color:var(--gold);}
.hero-stats{position:absolute;right:5%;bottom:11%;display:flex;gap:2px;}
.hero-stat{background:rgba(255,255,255,.05);border:1px solid rgba(201,168,76,.2);padding:1.2rem 1.6rem;text-align:center;backdrop-filter:blur(8px);}
.hero-stat:first-child{border-radius:10px 0 0 10px;}.hero-stat:last-child{border-radius:0 10px 10px 0;}
.hero-stat-num{font-family:'Playfair Display',serif;font-size:25px;color:var(--gold);font-weight:700;line-height:1;}
.hero-stat-lbl{font-size:10px;color:rgba(255,255,255,.47);margin-top:3px;letter-spacing:.06em;text-transform:uppercase;}

/* ── TRUST BAR ── */
.trust-bar{background:var(--gold-pale);border-top:1px solid #E8DFC4;border-bottom:1px solid #E8DFC4;padding:.95rem 5%;display:flex;align-items:center;justify-content:center;gap:2.2rem;flex-wrap:wrap;}
.ti{display:flex;align-items:center;gap:7px;font-size:12.5px;color:var(--navy-mid);font-weight:500;}
.ti svg{width:14px;height:14px;flex-shrink:0;}

/* ── SECTIONS ── */
section{padding:78px 5%;}
.sl{font-size:11px;letter-spacing:.16em;text-transform:uppercase;color:var(--gold);margin-bottom:.85rem;display:flex;align-items:center;gap:8px;}
.sl::before{content:'';width:20px;height:1px;background:var(--gold);}
.st{font-family:'Playfair Display',serif;font-size:clamp(1.85rem,3vw,2.65rem);font-weight:700;color:var(--navy);line-height:1.2;margin-bottom:.85rem;}
.sd{font-size:15px;color:var(--tm);line-height:1.8;max-width:520px;font-weight:300;}

/* ── ABOUT ── */
.about{background:var(--white);}
.about-grid{display:grid;grid-template-columns:1fr 1fr;gap:64px;align-items:start;}
.about-visual{position:relative;height:auto;min-height:320px;}
.about-main{background:var(--navy);border-radius:14px;padding:2rem;position:relative;overflow:hidden;margin-bottom:16px;}
.about-main::before{content:'';position:absolute;inset:0;background:linear-gradient(135deg,rgba(201,168,76,.08),transparent 60%);}
.about-main-tag{font-size:10px;letter-spacing:.15em;text-transform:uppercase;color:var(--gold);margin-bottom:8px;}
.about-main-text{font-family:'Playfair Display',serif;font-size:19px;color:#fff;line-height:1.38;position:relative;z-index:1;}
.about-stats-row{display:grid;grid-template-columns:1fr 1fr;gap:12px;}
.about-stat-card{background:var(--gold);border-radius:10px;padding:1.2rem;}
.about-stat-card.dark{background:var(--navy-mid);}
.about-stat-num{font-family:'Playfair Display',serif;font-size:30px;color:var(--navy);font-weight:700;line-height:1;}
.about-stat-card.dark .about-stat-num{color:var(--gold);}
.about-stat-lbl{font-size:12px;color:var(--navy-mid);margin-top:2px;}
.about-stat-card.dark .about-stat-lbl{color:rgba(255,255,255,.55);}
.about-text p{font-size:14.5px;color:var(--tm);line-height:1.82;margin-bottom:1rem;}
.about-text p:last-child{margin-bottom:0;}
.about-highlights{display:flex;flex-wrap:wrap;gap:8px;margin-top:1.2rem;}
.about-tag{display:inline-flex;align-items:center;gap:5px;background:var(--gold-pale);border:1px solid #E8DFC4;border-radius:20px;padding:5px 12px;font-size:12.5px;color:var(--navy-mid);font-weight:500;}
.about-tag::before{content:'✓';color:var(--gold);}

/* ── SERVICES ── */
.services{background:var(--off);}
.stabs{display:flex;gap:7px;flex-wrap:wrap;margin-bottom:1.8rem;}
.stab{padding:7px 16px;border-radius:30px;font-size:13px;font-weight:500;cursor:pointer;border:1px solid var(--bdr);background:#fff;color:var(--tmu);transition:all .2s;font-family:'DM Sans',sans-serif;}
.stab.active,.stab:hover{background:var(--navy);color:#fff;border-color:var(--navy);}
.svc-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:16px;}
.svc-card{background:#fff;border:1px solid var(--bdr);border-radius:13px;padding:1.6rem;transition:all .25s;position:relative;overflow:hidden;}
.svc-card::before{content:'';position:absolute;top:0;left:0;right:0;height:3px;background:linear-gradient(90deg,var(--gold),var(--gold-light));transform:scaleX(0);transform-origin:left;transition:transform .3s;}
.svc-card:hover{border-color:var(--gold);box-shadow:0 8px 28px rgba(11,31,58,.09);transform:translateY(-3px);}
.svc-card:hover::before{transform:scaleX(1);}
.svc-icon{width:48px;height:48px;border-radius:11px;background:var(--navy);display:flex;align-items:center;justify-content:center;margin-bottom:1.1rem;}
.svc-icon svg{width:24px;height:24px;}
.svc-name{font-family:'Playfair Display',serif;font-size:16.5px;font-weight:600;color:var(--navy);margin-bottom:.45rem;}
.svc-desc{font-size:13px;color:var(--tm);line-height:1.7;}
.svc-rate{margin-top:.8rem;font-size:12px;color:var(--tmu);}
.svc-rate strong{color:var(--navy);font-weight:500;}
.svc-wa{margin-top:.9rem;display:inline-flex;align-items:center;gap:5px;font-size:12.5px;font-weight:500;color:var(--gold);cursor:pointer;border:none;background:none;font-family:'DM Sans',sans-serif;padding:0;}
.svc-wa:hover{color:var(--navy);}

/* ── ELIGIBILITY CHECKER ── */
.elig{background:var(--navy);padding:78px 5%;}
.elig-inner{max-width:900px;margin:0 auto;}
.elig .st{color:#fff;}
.elig .sd{color:rgba(255,255,255,.55);}
.elig-form{background:rgba(255,255,255,.05);border:1px solid rgba(201,168,76,.2);border-radius:16px;padding:2rem;margin-top:2rem;}
.elig-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:16px;margin-bottom:20px;}
.ef-group label{font-size:11px;text-transform:uppercase;letter-spacing:.1em;color:rgba(255,255,255,.5);display:block;margin-bottom:6px;}
.ef-group input,.ef-group select{width:100%;padding:10px 12px;border:1px solid rgba(255,255,255,.15);border-radius:8px;font-size:14px;color:#fff;background:rgba(255,255,255,.08);font-family:'DM Sans',sans-serif;outline:none;transition:border .2s;}
.ef-group input::placeholder{color:rgba(255,255,255,.3);}
.ef-group select option{background:#152D52;color:#fff;}
.ef-group input:focus,.ef-group select:focus{border-color:var(--gold);}
.elig-btn{background:var(--gold);color:var(--navy);border:none;padding:12px 32px;border-radius:8px;font-size:15px;font-weight:500;cursor:pointer;font-family:'DM Sans',sans-serif;transition:background .2s;}
.elig-btn:hover{background:var(--gold-light);}
.elig-result{margin-top:1.8rem;background:rgba(201,168,76,.08);border:1px solid rgba(201,168,76,.3);border-radius:12px;padding:1.6rem;display:none;}
.elig-result.show{display:block;}
.elig-result-title{font-size:13px;text-transform:uppercase;letter-spacing:.12em;color:var(--gold);margin-bottom:1rem;}
.elig-max{font-family:'Playfair Display',serif;font-size:38px;font-weight:700;color:var(--gold);line-height:1;margin-bottom:4px;}
.elig-max-lbl{font-size:13px;color:rgba(255,255,255,.5);margin-bottom:1.2rem;}
.elig-loans{display:flex;flex-wrap:wrap;gap:8px;margin-bottom:1.4rem;}
.elig-loan-tag{background:rgba(255,255,255,.1);border:1px solid rgba(201,168,76,.3);border-radius:20px;padding:5px 13px;font-size:12.5px;color:#fff;}
.elig-apply{display:inline-flex;align-items:center;gap:8px;background:#25D366;color:#fff;border:none;padding:12px 22px;border-radius:8px;font-size:14px;font-weight:500;cursor:pointer;font-family:'DM Sans',sans-serif;}
.elig-apply:hover{background:#1EBE5A;}
.elig-note{font-size:11.5px;color:rgba(255,255,255,.35);margin-top:.8rem;}

/* ── BANK PARTNERS ── */
.partners{background:var(--white);padding:60px 5%;}
.partners-logos{display:flex;align-items:center;justify-content:center;flex-wrap:wrap;gap:24px;margin-top:2rem;}
.partner-logo{display:flex;align-items:center;justify-content:center;background:#fff;border:1px solid var(--bdr);border-radius:10px;padding:14px 22px;transition:box-shadow .2s;min-width:110px;height:60px;}
.partner-logo:hover{box-shadow:0 4px 18px rgba(11,31,58,.1);}
.partner-logo img{height:28px;width:auto;object-fit:contain;filter:grayscale(20%);}

/* ── WHY US ── */
.whyus{background:var(--navy);}
.whyus .st{color:#fff;}.whyus .sd{color:rgba(255,255,255,.55);}
.whyus-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:1px;margin-top:2.8rem;background:rgba(255,255,255,.08);border-radius:14px;overflow:hidden;}
.wi{background:rgba(11,31,58,.95);padding:1.8rem 1.4rem;text-align:center;transition:background .2s;}
.wi:hover{background:var(--navy-light);}
.wi-num{font-family:'Playfair Display',serif;font-size:34px;color:var(--gold);font-weight:700;line-height:1;margin-bottom:4px;}
.wi-lbl{font-size:12px;color:rgba(255,255,255,.55);line-height:1.5;}

/* ── PROCESS ── */
.process{background:#fff;}
.process-steps{display:grid;grid-template-columns:repeat(4,1fr);gap:0;margin-top:2.8rem;position:relative;}
.process-steps::before{content:'';position:absolute;top:26px;left:12.5%;right:12.5%;height:1px;background:linear-gradient(90deg,transparent,var(--gold),var(--gold),transparent);opacity:.3;}
.ps{text-align:center;padding:0 .9rem;}
.ps-bubble{width:52px;height:52px;border-radius:50%;background:var(--navy);color:var(--gold);font-family:'Playfair Display',serif;font-size:18px;font-weight:700;display:flex;align-items:center;justify-content:center;margin:0 auto 1rem;position:relative;z-index:1;border:3px solid var(--gold-pale);}
.ps-title{font-size:14px;font-weight:500;color:var(--navy);margin-bottom:4px;}
.ps-desc{font-size:12.5px;color:var(--tmu);line-height:1.65;}

/* ── FAQ ── */
.faq{background:var(--off);padding:78px 5%;}
.faq-inner{max-width:820px;}
.faq-list{margin-top:2rem;display:flex;flex-direction:column;gap:10px;}
.faq-item{background:#fff;border:1px solid var(--bdr);border-radius:11px;overflow:hidden;transition:border-color .2s;}
.faq-item.open{border-color:var(--gold);}
.faq-q{display:flex;justify-content:space-between;align-items:center;padding:1.1rem 1.4rem;cursor:pointer;gap:12px;}
.faq-q-text{font-size:14.5px;font-weight:500;color:var(--navy);line-height:1.4;}
.faq-icon{width:22px;height:22px;border-radius:50%;background:var(--gold-pale);border:1px solid #E8DFC4;display:flex;align-items:center;justify-content:center;flex-shrink:0;transition:background .2s,transform .3s;}
.faq-item.open .faq-icon{background:var(--gold);transform:rotate(45deg);}
.faq-icon svg{width:11px;height:11px;color:var(--navy);}
.faq-a{display:none;padding:0 1.4rem 1.2rem;font-size:13.5px;color:var(--tm);line-height:1.75;}
.faq-item.open .faq-a{display:block;}

/* ── CTA BAND ── */
.cta-band{background:linear-gradient(135deg,var(--navy),var(--navy-light));padding:78px 5%;display:flex;align-items:center;justify-content:space-between;gap:3rem;flex-wrap:wrap;}
.cta-band .st{color:#fff;margin-bottom:.55rem;}
.cta-band p{font-size:15px;color:rgba(255,255,255,.5);font-weight:300;}
.mini-form{background:#fff;border-radius:14px;padding:1.8rem;width:100%;max-width:400px;box-shadow:0 20px 55px rgba(0,0,0,.2);}
.mini-form h3{font-family:'Playfair Display',serif;font-size:19px;color:var(--navy);margin-bottom:1.2rem;}
.ff{margin-bottom:12px;}
.ff label{font-size:11px;color:var(--tmu);display:block;margin-bottom:4px;letter-spacing:.04em;text-transform:uppercase;}
.ff input,.ff select{width:100%;padding:9px 11px;border:1px solid var(--bdr);border-radius:8px;font-size:13.5px;color:var(--navy);background:var(--off);font-family:'DM Sans',sans-serif;outline:none;transition:border .2s;}
.ff input:focus,.ff select:focus{border-color:var(--gold);background:#fff;}
.wa-note{display:flex;align-items:center;gap:6px;margin-top:8px;font-size:11.5px;color:var(--tmu);justify-content:center;}

/* ── EMI PAGE ── */
.emi-page{padding:106px 5% 60px;}
.emi-wrap{display:grid;grid-template-columns:1fr 1fr;gap:44px;align-items:start;max-width:960px;}
.emi-card{background:#fff;border:1px solid var(--bdr);border-radius:16px;padding:1.8rem;}
.emi-card h2{font-family:'Playfair Display',serif;font-size:22px;color:var(--navy);margin-bottom:1.4rem;}
.slg{margin-bottom:1.4rem;}
.slr{display:flex;justify-content:space-between;margin-bottom:6px;}
.slr span:first-child{font-size:12.5px;color:var(--tmu);}
.slr span:last-child{font-size:13.5px;font-weight:500;color:var(--navy);}
input[type=range]{width:100%;accent-color:var(--gold);cursor:pointer;}
.emi-result{background:var(--navy);border-radius:16px;padding:1.8rem;color:#fff;}
.emi-result h3{font-size:10.5px;letter-spacing:.14em;text-transform:uppercase;color:var(--gold);margin-bottom:1.3rem;}
.emi-big{font-family:'Playfair Display',serif;font-size:42px;font-weight:700;color:var(--gold);line-height:1;margin-bottom:.35rem;}
.emi-sub{font-size:12px;color:rgba(255,255,255,.42);margin-bottom:1.6rem;}
.emi-rows{display:flex;flex-direction:column;gap:11px;}
.er{display:flex;justify-content:space-between;padding-bottom:10px;border-bottom:1px solid rgba(255,255,255,.08);}
.er:last-child{border:none;}
.er-l{font-size:12.5px;color:rgba(255,255,255,.5);}
.er-v{font-size:14px;font-weight:500;color:#fff;}
.emi-bar-wrap{margin-top:1.2rem;}
.emi-bar-lbls{display:flex;justify-content:space-between;font-size:10.5px;color:rgba(255,255,255,.38);margin-bottom:4px;}
.emi-bar{height:8px;border-radius:4px;background:rgba(255,255,255,.1);display:flex;overflow:hidden;}
.emi-bar-p{background:var(--gold);transition:width .4s;}
.emi-bar-i{background:rgba(201,168,76,.28);transition:width .4s;}
.emi-wa{width:100%;margin-top:1.4rem;display:flex;align-items:center;justify-content:center;gap:8px;background:#25D366;color:#fff;border:none;padding:12px;border-radius:8px;font-size:14px;font-weight:500;cursor:pointer;font-family:'DM Sans',sans-serif;}
.emi-wa:hover{background:#1EBE5A;}

/* ── CONTACT PAGE ── */
.contact-page{padding:106px 5% 60px;}
.contact-grid{display:grid;grid-template-columns:1fr 1.3fr;gap:46px;align-items:start;max-width:960px;}
.contact-info h2{font-family:'Playfair Display',serif;font-size:1.9rem;color:var(--navy);margin-bottom:.9rem;}
.contact-info p{font-size:14.5px;color:var(--tm);line-height:1.8;margin-bottom:1.6rem;}
.cm{display:flex;gap:13px;align-items:flex-start;margin-bottom:1.3rem;}
.cm-icon{width:40px;height:40px;border-radius:9px;background:var(--gold-pale);border:1px solid #E8DFC4;display:flex;align-items:center;justify-content:center;flex-shrink:0;}
.cm-icon svg{width:16px;height:16px;}
.cm-title{font-size:11.5px;color:var(--tmu);margin-bottom:2px;}
.cm-val{font-size:14.5px;font-weight:500;color:var(--navy);}
.wa-big{display:flex;align-items:center;gap:10px;background:#25D366;color:#fff;padding:13px 20px;border-radius:9px;text-decoration:none;font-size:14.5px;font-weight:500;margin-top:1.6rem;transition:background .2s;border:none;cursor:pointer;font-family:'DM Sans',sans-serif;width:fit-content;}
.wa-big:hover{background:#1EBE5A;}
.wa-big svg{width:20px;height:20px;flex-shrink:0;}
.cf-box{background:#fff;border:1px solid var(--bdr);border-radius:15px;padding:1.8rem;box-shadow:0 6px 28px rgba(11,31,58,.06);}
.cf-box h3{font-family:'Playfair Display',serif;font-size:21px;color:var(--navy);margin-bottom:1.3rem;}
.form-row{display:grid;grid-template-columns:1fr 1fr;gap:11px;}
.ff textarea{width:100%;padding:9px 11px;border:1px solid var(--bdr);border-radius:8px;font-size:13.5px;color:var(--navy);background:var(--off);font-family:'DM Sans',sans-serif;outline:none;transition:border .2s;min-height:72px;resize:vertical;}
.ff textarea:focus{border-color:var(--gold);background:#fff;}

/* ── FOOTER ── */
footer{background:#060F1E;padding:2.8rem 5% 1.8rem;}
.footer-top{display:flex;gap:3rem;flex-wrap:wrap;padding-bottom:1.8rem;border-bottom:1px solid rgba(255,255,255,.07);margin-bottom:1.8rem;}
.footer-brand{flex:2;min-width:200px;}
