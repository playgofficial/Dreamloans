<script>
// CONFIG — WhatsApp number
const WA_NUM = '919821081926';

function waOpen(msg){ window.open('https://wa.me/'+WA_NUM+'?text='+encodeURIComponent(msg),'_blank'); }
function waApply(loan){ waOpen('Hi Dream Loans! 🙏 I am interested in a *'+loan+'*. Please share details and eligibility.'); }
function showToast(m){ const t=document.getElementById('toast'); t.textContent=m; t.classList.add('show'); setTimeout(()=>t.classList.remove('show'),3200); }

// Page Navigation
function goPage(p){
  document.querySelectorAll('.page').forEach(x=>x.classList.remove('active'));
  document.getElementById('page-'+p).classList.add('active');
  window.scrollTo({top:0,behavior:'instant'});
}
function goSec(id){
  goPage('home');
  setTimeout(()=>{ const el=document.getElementById(id); if(el) el.scrollIntoView({behavior:'smooth'}); },90);
}
function toggleMob(){ document.getElementById('mobMenu').classList.toggle('open'); }

// Service Filter
function filterSvc(cat,btn){
  document.querySelectorAll('.stab').forEach(b=>b.classList.remove('active')); btn.classList.add('active');
  document.querySelectorAll('.svc-card').forEach(c=>{ c.style.display=(cat==='all'||c.dataset.cat===cat)?'':'none'; });
}

// Home Form
function submitHome(){
  const name=document.getElementById('hf-name').value.trim();
  const phone=document.getElementById('hf-phone').value.trim();
  const type=document.getElementById('hf-type').value;
  const amt=document.getElementById('hf-amt').value;
  if(!name){showToast('Please enter your name');return;}
  if(phone.length<10){showToast('Please enter a valid mobile number');return;}
  waOpen(`Hi Dream Loans! 🙏\n\n*Loan Enquiry*\n*Name:* ${name}\n*Phone:* ${phone}\n*Loan:* ${type}\n*Amount:* ${amt}\n\nPlease guide me on next steps.`);
  showToast('✓ Opening WhatsApp with your details!');
}

// Contact Form
function submitContact(){
  const name=document.getElementById('cf-name').value.trim();
  const phone=document.getElementById('cf-phone').value.trim();
  const type=document.getElementById('cf-type').value;
  const amt=document.getElementById('cf-amt').value;
  const extra=document.getElementById('cf-msg').value.trim();
  if(!name){showToast('Please enter your name');return;}
  if(phone.length<10){showToast('Please enter a valid mobile number');return;}
  let msg=`Hi Dream Loans! 🙏\n\n*Enquiry Form*\n*Name:* ${name}\n*Phone:* ${phone}\n*Loan:* ${type}\n*Amount:* ${amt}`;
  if(extra) msg+=`\n*Message:* ${extra}`;
  msg+='\n\nPlease guide me!';
  waOpen(msg); showToast('✓ Opening WhatsApp — we\'ll reply shortly!');
}

// Eligibility Checker
let eligLoans=[];
function checkEligibility(){
  const income=parseInt(document.getElementById('el-income').value)||0;
  const age=parseInt(document.getElementById('el-age').value)||0;
  const emp=document.getElementById('el-emp').value;
  const cibil=parseInt(document.getElementById('el-cibil').value)||750;
  const city=document.getElementById('el-city').value.trim();
  if(!income||income<5000){showToast('Please enter monthly income (min ₹5,000)');return;}
  if(!age||age<18){showToast('Please enter a valid age (18+)');return;}
  if(!emp){showToast('Please select employment type');return;}

  let mult = emp==='salaried' ? 60 : emp==='selfemployed' ? 48 : 36;
  if(cibil>=750) mult*=1; else if(cibil>=700) mult*=0.9; else if(cibil>=650) mult*=0.75; else mult*=0.55;
  if(age>55) mult*=0.8; else if(age<25) mult*=0.9;
  const maxLoan = Math.round((income * mult)/100)*100;

  eligLoans=[];
  if(emp==='salaried'||emp==='selfemployed'){ if(cibil>=650) eligLoans.push('Personal Loan'); }
  if(emp==='farmer'||emp==='selfemployed') eligLoans.push('Used Tractor Loan');
  eligLoans.push('Gold Loan');
  if(maxLoan>=100000) eligLoans.push('Two Wheeler Loan');
  if(maxLoan>=300000){ eligLoans.push('New Car Loan'); eligLoans.push('Used Car Loan'); }
  if(maxLoan>=500000) eligLoans.push('Business Loan');
  if(maxLoan>=1000000){ eligLoans.push('Home Loan'); eligLoans.push('Loan Against Property'); }

  const inr=n=>'₹'+n.toLocaleString('en-IN');
  document.getElementById('er-max').textContent=inr(maxLoan);
  document.getElementById('er-lbl').textContent=`Estimated max loan amount for you${city?' in '+city:''}`;
  const loansEl=document.getElementById('er-loans');
  loansEl.innerHTML=eligLoans.map(l=>`<span class="elig-loan-tag">${l}</span>`).join('');
  document.getElementById('elig-result').classList.add('show');
  document.getElementById('elig-result').scrollIntoView({behavior:'smooth',block:'nearest'});
}

function applyEligResult(){
  const income=document.getElementById('el-income').value;
  const loans=eligLoans.join(', ');
  const max=document.getElementById('er-max').textContent;
  waOpen(`Hi Dream Loans! 🙏\nI checked my eligibility on your website.\n\n*Monthly Income:* ₹${income}\n*Eligible For:* ${loans}\n*Estimated Loan Amount:* ${max}\n\nPlease help me apply!`);
}

// EMI Calculator
function inr(n){ return '₹'+Math.round(n).toLocaleString('en-IN'); }
function calcEMI(){
  const P=+document.getElementById('sl-a').value;
  const r=+document.getElementById('sl-r').value/12/100;
  const n=+document.getElementById('sl-t').value;
  document.getElementById('lbl-a').textContent=inr(P);
  document.getElementById('lbl-r').textContent=(+document.getElementById('sl-r').value).toFixed(1)+'%';
  document.getElementById('lbl-t').textContent=n+' months';
  const emi=(P*r*Math.pow(1+r,n))/(Math.pow(1+r,n)-1);
  const total=emi*n; const interest=total-P;
  document.getElementById('e-emi').textContent=inr(emi);
  document.getElementById('e-p').textContent=inr(P);
  document.getElementById('e-i').textContent=inr(interest);
  document.getElementById('e-tot').textContent=inr(total);
  document.getElementById('e-ten').textContent=n+' months';
  const pp=Math.round(P/total*100);
  document.getElementById('e-bp').style.width=pp+'%';
  document.getElementById('e-bi').style.width=(100-pp)+'%';
}
function setRate(v){ document.getElementById('sl-r').value=v; calcEMI(); }
function applyEMI(){
  const emi=document.getElementById('e-emi').textContent;
  const amt=document.getElementById('lbl-a').textContent;
  const rate=document.getElementById('lbl-r').textContent;
  const ten=document.getElementById('lbl-t').textContent;
  waOpen(`Hi Dream Loans! 🙏\nI used your EMI Calculator:\n*Loan Amount:* ${amt}\n*Rate:* ${rate} p.a.\n*Tenure:* ${ten}\n*EMI:* ${emi}/month\n\nI'd like to apply. Please guide me!`);
}
calcEMI();

// FAQ
const faqs=[ /* ... all your FAQs here (same as before) ... */ ];

function buildFAQ(){
  const list=document.getElementById('faqList');
  faqs.forEach((f,i)=>{
    const item=document.createElement('div'); item.className='faq-item';
    item.innerHTML=`<div class="faq-q" onclick="toggleFAQ(${i})"><span class="faq-q-text">${f.q}</span><span class="faq-icon"><svg viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="6" y1="1" x2="6" y2="11"/><line x1="1" y1="6" x2="11" y2="6"/></svg></span></div><div class="faq-a">${f.a}</div>`;
    list.appendChild(item);
  });
}
function toggleFAQ(i){
  const items=document.querySelectorAll('.faq-item');
  items[i].classList.toggle('open');
}
buildFAQ();

// Scroll Reveal
const obs=new IntersectionObserver(entries=>{
  entries.forEach(e=>{ if(e.isIntersecting){ e.target.style.opacity='1'; e.target.style.transform='translateY(0)'; }});
},{threshold:0.08});
document.querySelectorAll('.svc-card,.ps,.wi,.partner-logo').forEach(el=>{
  el.style.opacity='0'; el.style.transform='translateY(15px)'; el.style.transition='opacity .5s ease,transform .5s ease';
  obs.observe(el);
});
</script>
